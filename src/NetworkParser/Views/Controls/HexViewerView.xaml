<UserControl
    x:Class="NetworkParser.Views.Controls.HexViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NetworkParser.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

    <Grid DataContext="{Binding HexViewerVM}">
        <ScrollViewer>
            <TextBlock
            FontFamily="Consolas"
            Text="{Binding HexDump}"
            TextWrapping="NoWrap"/>
        </ScrollViewer>

        <Button
            Content="⎘"
            FontSize="14"
            Width="32"
            Height="32"
            Padding="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,8,8"
            Opacity="0.5"
            Canvas.ZIndex="1"
            ToolTipService.ToolTip="Copy Hex"
            Click="OnCopyHex"/>
    </Grid>
</UserControl>
