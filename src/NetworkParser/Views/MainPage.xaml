<Page
    x:Class="NetworkParser.UI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NetworkParser.UI.Views"
    xmlns:controls="using:NetworkParser.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Background="{ThemeResource CommandBarBackground}">
            <Button Content="Start" Command="{Binding StartCaptureCommand}" />
            <Button Content="Stop"  Command="{Binding StopCaptureCommand}" />
            <Button Content="Interfaces" Command="{Binding OpenInterfacesCommand}" />

            <TextBox Width="300" PlaceholderText="Filter" Text="{Binding FilterText, Mode=TwoWay}" />
            <Button Content="Apply" Command="{Binding ApplyFilterCommand}" />
        </StackPanel>

        <!-- PACKET LIST -->
        <controls:PacketListView Grid.Row="1"/>

        <!-- DETAILS -->
        <controls:PacketDetailsView Grid.Row="2"/>

        <!-- HEX -->
        <controls:HexViewerView Grid.Row="3"/>
    </Grid>
</Page>
