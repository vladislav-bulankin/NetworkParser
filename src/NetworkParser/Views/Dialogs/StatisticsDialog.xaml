<ContentDialog
    x:Class="NetworkParser.UI.Views.Dialogs.StatisticsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NetworkParser.UI.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Capture Statistics"
    CloseButtonText="Close"
    MinWidth="650">
    <ScrollViewer MaxHeight="600">
        <StackPanel Spacing="20" Padding="0,8,0,0">

            <!-- Общая инфо -->
            <StackPanel>
                <TextBlock Text="General" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                <Grid ColumnSpacing="24" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding TotalPacketsLabel}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalBytesLabel}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DurationLabel}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AvgSizeLabel}"/>
                </Grid>
            </StackPanel>

            <!-- Топ протоколов -->
            <StackPanel>
                <TextBlock Text="Top Protocols" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding TopProtocols}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" Text="{Binding Count}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="{Binding Percent}" Opacity="0.6" HorizontalAlignment="Right"/>
                                <ProgressBar Grid.Column="3" Value="{Binding BarValue}" Maximum="100" Height="6" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Топ IP -->
            <StackPanel>
                <TextBlock Text="Top Sources" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding TopSources}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" Text="{Binding Count}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="{Binding Percent}" Opacity="0.6" HorizontalAlignment="Right"/>
                                <ProgressBar Grid.Column="3" Value="{Binding BarValue}" Maximum="100" Height="6" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Топ conversations -->
            <StackPanel>
                <TextBlock Text="Top Conversations" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding TopConversations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontFamily="Consolas" TextWrapping="NoWrap"/>
                                <TextBlock Grid.Column="1" Text="{Binding Count}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="{Binding Percent}" Opacity="0.6" HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
